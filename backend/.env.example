# ============================================================
# .env.example – Backend-Umgebungsvariablen
# Kopiere diese Datei als ".env" und fülle alle Werte aus.
# Die .env Datei wird NIEMALS in Git eingecheckt!
# ============================================================

# --- Supabase ---
# Zu finden unter: Supabase Dashboard → Settings → API
SUPABASE_URL=https://iktywneibdguviptvkue.supabase.co
SUPABASE_ANON_KEY=dein-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=dein-supabase-service-role-key

# --- Google Gemini ---
# Zu finden unter: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=dein-gemini-api-key

# --- JWT ---
# Beliebiger langer, zufälliger String (min. 32 Zeichen)
JWT_SECRET=ersetze-das-durch-einen-langen-zufaelligen-string-z.B.-openssl-rand-hex-32

# --- Server ---
PORT=3000

# --- CORS ---
# Im Deployment: deine GitHub-Pages-URL, z.B. https://martinovic-uibk.github.io
# Für lokale Entwicklung: http://localhost:5500 oder ähnlich
ALLOWED_ORIGIN=https://martinovic-uibk.github.io
